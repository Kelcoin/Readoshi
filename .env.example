# ==========================================
#  LANraragi-React 环境变量
#  复制为 .env.local 后使用 (Vite 开发)
# ==========================================


# ── Vite 开发服务器 ────────────────────────

# 反向代理域名白名单 (逗号分隔多个)
# 当开发服务器通过 Nginx/Lucky 等反向代理对外暴露时必填
# Vite 默认只允许 localhost，此处填入外部域名可防止 "Invalid Host header" 错误
# 示例: reader.example.com,lanraragi.example.com
VITE_ALLOWED_HOSTS=reader.example.com,lanraragi.example.com

# 强制所有出站请求仅使用 IPv4
# 默认双栈模式 (Node 18+ autoSelectFamily, IPv4/IPv6 并行)
# 当服务器某个协议栈不可达导致长时间等待时设置为 true
VITE_FORCE_IPV4=false
